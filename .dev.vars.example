# CRITICAL: DO NOT SET SUPABASE_JWT_SECRET — this project uses ES256 JWKS verification.
# Setting SUPABASE_JWT_SECRET would bypass asymmetric verification and create a security hole.
#
# Copy this file to .env.local for local Next.js development.
# .env.local is gitignored.  This example file is committed.

# ──────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://kxsdzaojfaibhuzmclfq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REDACTED
SUPABASE_SERVICE_ROLE_KEY=REDACTED

# Postgres connection — session pooler (port 5432) or direct connection work fine on Render.
DATABASE_TRANSACTION_POOLER_URL=REDACTED  # postgresql://postgres.kxsdzaojfaibhuzmclfq:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ──────────────────────────────────────────────
# Empowered Accounts (SSO + JWT)
# ──────────────────────────────────────────────
ACCOUNTS_API_BASE=https://api.empowered.vote
JWKS_URL=https://kxsdzaojfaibhuzmclfq.supabase.co/auth/v1/.well-known/jwks.json

# ──────────────────────────────────────────────
# Empowered Accounts service keys (Phase 4+)
# ──────────────────────────────────────────────
LISTENING_GEM_KEY=REDACTED
LISTENING_XP_KEY=REDACTED

# ──────────────────────────────────────────────
# LiveKit (Phase 2)
# ──────────────────────────────────────────────
LIVEKIT_URL=REDACTED
LIVEKIT_API_KEY=REDACTED
LIVEKIT_API_SECRET=REDACTED

# ──────────────────────────────────────────────
# Mux (Phase 3 — video streaming)
# ──────────────────────────────────────────────
MUX_TOKEN_ID=REDACTED
MUX_TOKEN_SECRET=REDACTED
MUX_WEBHOOK_SECRET=REDACTED

# ──────────────────────────────────────────────
# AWS S3 (recordings storage)
# ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=REDACTED
AWS_SECRET_ACCESS_KEY=REDACTED
AWS_S3_BUCKET_NAME=empowered-listening-recordings
AWS_REGION=us-east-1

# ──────────────────────────────────────────────
# Deepgram (Phase 4)
# ──────────────────────────────────────────────
DEEPGRAM_API_KEY=REDACTED

# ──────────────────────────────────────────────
# Local development only
# ──────────────────────────────────────────────
# AUTH_BYPASS=1
